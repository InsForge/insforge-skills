# InsForge Postgres connection — Better Auth uses this to manage user/session/account/verification.
# Use a fully-granted role (postgres or project_admin), NOT anon/authenticated.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/insforge

# Better Auth's own session secret (random, ≥32 chars). Distinct from the InsForge JWT secret.
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-bytes
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# InsForge JWT secret — npx @insforge/cli secrets get JWT_SECRET. Server-only.
# This is what the bridge route signs HS256 tokens with.
INSFORGE_JWT_SECRET=replace-with-the-output-of-the-cli-secrets-get-command

# InsForge public credentials.
NEXT_PUBLIC_INSFORGE_ANON_KEY=replace-with-anon-key-from-insforge-dashboard
NEXT_PUBLIC_INSFORGE_BASE_URL=http://localhost:7130
