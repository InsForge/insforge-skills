# The SPA's own origin (Vite dev server). authClient uses this as its baseURL,
# and Vite proxies /api/* to the BA server (see vite.config.ts).
VITE_BETTER_AUTH_URL=http://localhost:5173

# InsForge public credentials.
VITE_INSFORGE_BASE_URL=http://localhost:7130
VITE_INSFORGE_ANON_KEY=replace-with-anon-key-from-insforge-dashboard
